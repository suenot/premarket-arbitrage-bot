# Premarket.me API key (JWT token)
PREMARKET_API_KEY=your_jwt_token_here

# Ethereum wallet (MetaMask)
ETH_WALLET=0xYourWalletAddress
ETH_SECRET="your twelve word mnemonic seed phrase from metamask"

# Bot settings
DRY_RUN=true
MIN_PROFIT_PCT=3
MIN_APR=10
MIN_DEPTH_USD=10
POLL_INTERVAL=30
MAX_TRADE_USD=50
